# Frontend (optional — dev proxy handles /api by default)
# VITE_API_URL=
# VITE_SITE_URL=https://azeemnaveed.com

# Backend
PORT=3001
NODE_ENV=development

# Comma-separated allowed origins for production CORS
# CORS_ORIGINS=https://azeemnaveed.com,https://www.azeemnaveed.com

# Email notifications (contact form + estimates)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=465
# SMTP_USER=your@gmail.com
# SMTP_PASS=your-app-password
# NOTIFY_EMAIL=azeemnaveed100@gmail.com

# Review moderation admin API (required for /api/reviews/admin)
# ADMIN_API_KEY=your-secure-random-key

# Serve built frontend from Express (set with NODE_ENV=production or explicitly)
# SERVE_FRONTEND=true
